#!/usr/bin/env bash
# send-message — deliver a message to a pane, waiting until the user is not mid-composition
# Usage: send-message <target_pane> <message>
set -euo pipefail

target="$1"
message="$2"
timeout=30
elapsed=0

# If target is not the currently focused pane, deliver immediately
active=$(tmux display-message -p '#{pane_id}')
if [[ "$target" != "$active" ]]; then
  tmux send-keys -t "$target" "$message" Enter
  exit 0
fi

# Target is focused — wait until cursor_x == 0 (empty input prompt)
while true; do
  cursor_x=$(tmux display-message -p -t "$target" '#{cursor_x}')
  if [[ "$cursor_x" -eq 0 ]]; then
    tmux send-keys -t "$target" "$message" Enter
    exit 0
  fi
  sleep 0.3
  elapsed=$(( elapsed + 1 ))
  if [[ $elapsed -ge $(( timeout * 3 )) ]]; then
    echo "send-message: timed out waiting for $target to be idle" >&2
    exit 1
  fi
done
