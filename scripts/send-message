#!/usr/bin/env bash
# send-message <name> <message...> — send a message to a named worker, waiting for an idle prompt
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

name="${1:-}"
shift || true
message="$*"

if [[ -z "$name" || -z "$message" ]]; then
  echo "Usage: send-message <name> <message>" >&2
  exit 1
fi

sender=$(tmux show-options -pv @worker-name 2>/dev/null || true)
if [[ -z "$sender" ]]; then
  sender="Unknown"
fi
message="${sender}: ${message}"

pane=$(_ma_get_pane_id_by_worker_name "$name")
if [[ -z "$pane" ]]; then
  echo "Error: no worker named '$name' found in the current window." >&2
  exit 1
fi

timeout=30
interval=0.5
elapsed=0

# Claude Code shows "? for shortcuts" in the status bar when idle (waiting for input)
# and "esc to interrupt" when actively generating. Grepping for "for shortcuts" is
# a heuristic — it depends on Claude Code's UI text not changing across versions.
until tmux capture-pane -p -t "$pane" | grep -q "for shortcuts"; do
  sleep "$interval"
  elapsed=$(echo "$elapsed + $interval" | bc)
  if (( $(echo "$elapsed >= $timeout" | bc -l) )); then
    echo "send-message: timed out waiting for idle prompt in '$name' (pane $pane)" >&2
    exit 1
  fi
done

tmux send-keys -t "$pane" "$message" Enter
echo "Sent to '$name' (pane $pane): $message"
