#!/usr/bin/env bash
# send-message <name> <message...> — send a message to a named worker, waiting for an idle prompt
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

name="${1:-}"
shift || true

# If no inline message is given, read from stdin (allows: cat /tmp/task.txt | send-message Wade)
if [[ $# -eq 0 ]]; then
  message="$(cat)"
else
  message="$*"
fi

if [[ -z "$name" || -z "$message" ]]; then
  echo "Usage: send-message <name> <message>" >&2
  echo "       cat /tmp/task.txt | send-message <name>" >&2
  exit 1
fi

sender=$(tmux show-options -p -t "$TMUX_PANE" -v @worker-name 2>/dev/null || true)
if [[ -z "$sender" ]]; then
  sender="Unknown"
fi
message="${sender}: ${message}"

pane=$(_ma_get_pane_id_by_worker_name "$name")
if [[ -z "$pane" ]]; then
  echo "Error: no worker named '$name' found in the current window." >&2
  exit 1
fi

idle_flag="/tmp/claude-idle-${pane}"
max_attempts=150  # 30s at 0.2s intervals
attempts=0
while [[ ! -f "$idle_flag" ]]; do
  if (( attempts >= max_attempts )); then
    echo "Error: timed out waiting for '$name' (pane $pane) to become idle." >&2
    exit 1
  fi
  sleep 0.2
  attempts=$(( attempts + 1 ))
done
rm -f "$idle_flag"

tmux send-keys -t "$pane" "$message" Enter
echo "Sent to '$name' (pane $pane): $message"
