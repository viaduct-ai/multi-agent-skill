#!/usr/bin/env bash
# notify-user — switch focus to a worker pane when it finishes a turn,
# unless it is already the active pane.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

if [[ -z "${TMUX_PANE:-}" ]]; then
  exit 0
fi

worker_name=$(_ma_get_worker_name "$TMUX_PANE")
if [[ -z "$worker_name" ]]; then
  exit 0
fi

# Already focused — nothing to do
is_active=$(tmux list-panes -F '#{pane_id} #{pane_active}' | awk -v p="$TMUX_PANE" '$1==p{print $2}')
if [[ "$is_active" == "1" ]]; then
  exit 0
fi

tmux select-pane -t "$TMUX_PANE"
