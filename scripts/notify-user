#!/usr/bin/env bash
# notify-user — show a tmux popup on Sage's pane alerting that a worker needs attention
# Called as a hook from worker panes; silently exits if not in a worker pane.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

# Check if we're in a worker pane
if [[ -z "${TMUX_PANE:-}" ]]; then
  exit 0
fi

worker_name=$(_ma_get_worker_name "$TMUX_PANE")
if [[ -z "$worker_name" ]]; then
  exit 0
fi

# Find Sage's pane
sage_pane=$(_ma_get_sage_pane)
target="${sage_pane:-$TMUX_PANE}"

# Skip popup if target pane is already focused
active=$(tmux display-message -t "$target" -p '#{pane_active}')
if [[ "$active" == "1" ]]; then
  exit 0
fi

last_used=$(tmux display-message -t "$target" -p '#{pane_last_used}')
now=$(date +%s)

if (( now - last_used > 3 )); then
  # User is idle — switch focus to the worker pane and notify there
  tmux select-pane -t "$TMUX_PANE"
  tmux display-message -t "$TMUX_PANE" -d 4000 " [$worker_name] needs your attention "
else
  # User is active — show notification on Sage's pane without switching
  tmux display-message -t "$target" -d 4000 " [$worker_name] needs your attention "
fi
