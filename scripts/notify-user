#!/usr/bin/env bash
# notify-user — show a tmux popup on Sage's pane alerting that a worker needs attention
# Called as a hook from worker panes; silently exits if not in a worker pane.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

# Check if we're in a worker pane
if [[ -z "${TMUX_PANE:-}" ]]; then
  exit 0
fi

worker_name=$(_ma_get_worker_name "$TMUX_PANE")
if [[ -z "$worker_name" ]]; then
  exit 0
fi

# Find Sage's pane
sage_pane=$(_ma_get_sage_pane)
target="${sage_pane:-$TMUX_PANE}"

tmux display-popup -t "$target" -E -w 60 -h 3 -x C -y 0 "echo '[$worker_name] needs your attention' && sleep 3"
